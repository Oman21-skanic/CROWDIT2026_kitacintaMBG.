":root {\n    --primary-color: #355C56; /* Dark Green from bubbles */\n    --primary-light: #EEF5F4; /* Light green for hover/active */\n    --text-dark: #1F2937;\n    --text-muted: #6B7280;\n    --text-white: #FFFFFF;\n    --bg-white: #FFFFFF;\n    --bg-app: #F5F9F8;\n    --border-color: #E5E7EB;\n    --sidebar-width: 280px;\n    \n    /* Bubble specific */\n    --bubble-sent-bg: #355C56;\n    --bubble-received-bg: #FFFFFF;\n}\n\n* {\n    margin: 0;\n    padding: 0;\n    box-sizing: border-box;\n}\n\nbody {\n    font-family: 'Inter', sans-serif;\n    color: var(--text-dark);\n    height: 100vh;\n    overflow: hidden;\n    background-color: var(--bg-app);\n}\n\n/* Backgrounds */\n.chat-background {\n    position: fixed;\n    top: 0;\n    left: var(--sidebar-width);\n    right: 0;\n    bottom: 0;\n    z-index: -1;\n    overflow: hidden;\n}\n\n.bg-gradient {\n    position: absolute;\n    top: -50px;\n    right: -100px;\n    width: 100%;\n    height: 100%;\n    display: flex;\n    justify-content: flex-end;\n    align-items: flex-start;\n    pointer-events: none;\n}\n\n.bg-gradient svg {\n    width: auto;\n    height: 120%;\n    max-height: none;\n}\n\n.bg-star {\n    position: absolute;\n    top: 50%;\n    left: 50%;\n    transform: translate(-50%, -50%);\n    width: 100%;\n    height: 100%;\n    display: flex;\n    justify-content: center;\n    align-items: center;\n    pointer-events: none;\n}\n\n.bg-star svg {\n    width: 90%;\n    height: auto;\n}\n\n/* App Container */\n.app-container {\n    display: flex;\n    height: 100vh;\n    width: 100%;\n}\n\n/* Sidebar */\n.sidebar {\n    width: var(--sidebar-width);\n    background-color: var(--bg-white);\n    display: flex;\n    flex-direction: column;\n    padding: 20px;\n    border-right: 1px solid var(--border-color);\n    z-index: 10;\n}\n\n.sidebar-header {\n    display: flex;\n    align-items: center;\n    justify-content: space-between;\n    margin-bottom: 24px;\n}\n\n.logo {\n    display: flex;\n    align-items: center;\n    gap: 12px;\n    font-weight: 600;\
